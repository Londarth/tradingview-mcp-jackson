# ─── Alpaca ───
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_PAPER=true

# ─── Telegram ───
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ─── Strategy ───
UNIVERSE=PLTR,LCID,SOFI,MARA,BTDR,DKNG,QS,SMR,UEC,IONQ,NCLH,SOUN,CLSK
ATR_PCT_THRESHOLD=0.25
TARGET_FIB=0.618
RR_RATIO=2.0
POSITION_PCT=10
RISK_PCT=0
MIN_ATR=0.50
MIN_POSITION_USD=100

# ─── Session ───
SESSION_END=1100
HARD_EXIT=1130
POLL_INTERVAL_MS=30000
UNFILLED_TIMEOUT_MIN=15

# ─── Risk Management ───
DAILY_LOSS_LIMIT_PCT=3
MAX_EQUITY_PCT=30

# ─── API ───
API_TIMEOUT_MS=30000

# ─── Scanner ───
SCANNER_TOP_N=5
WATCHLIST_PATH=scripts/watchlist.json

# ─── Dry Run ───
DRY_RUN=false

# ─── Backtest ───
SLIPPAGE_BPS=5
COMMISSION_PER_SHARE=0.005